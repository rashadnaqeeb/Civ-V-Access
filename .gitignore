# Local planning notes (not part of the shipped mod)
.planning/

# Build artifacts (always regenerated)
*.obj
*.o
*.exp
*.pdb
*.ilk
*.res
*.user
*.suo

# Build directories
build/
out/
bin/
obj/
x64/
Debug/
Release/

# IDE / editor
.vs/
.vscode/
.idea/
.claude/

# OS
Thumbs.db
Desktop.ini
.DS_Store

# Logs
*.log

# Tolk source-tree build outputs (keep source, drop artifacts).
# The redistributable binaries live in third_party/tolk/dist/ and libs/ and are tracked.
third_party/tolk/src/*.dll
third_party/tolk/src/*.lib

# Local-only config (game install path, personal overrides)
local.config
local.*.ini

# Locally-installed developer tools (luacheck, etc.)
tools/bin/

# RemuxToAsf is a built-from-source C# helper; the .exe is regenerated on demand
tools/RemuxToAsf.exe

# luacheck cache
.luacheckcache

# Extracted leader scene images (Firaxis assets — not redistributable)
/leader images/

# Release artifacts produced by package-release.ps1. The GitHub Release is the
# source of truth for shipped binaries; the local zips are byproducts.
dist/release/

# dist/installer/CivVAccessInstaller.exe IS committed - the file at that path
# gives players a stable raw link
# (https://github.com/rashadnaqeeb/Civ-V-Access/raw/main/dist/installer/CivVAccessInstaller.exe)
# that survives across releases. Rebuild via build-installer.ps1 only when
# installer/ source changed since the last release; commit the new exe in the
# same commit as the corresponding versions.json + CHANGELOG bump.
